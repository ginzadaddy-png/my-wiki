# Anthropic API key — console.anthropic.com에서 발급
# 발급 후 이 파일을 .env로 복사하고 실제 값으로 채우기
ANTHROPIC_API_KEY=sk-ant-...

# vault 경로 (기본값 사용 시 생략 가능)
VAULT_PATH=C:\Vault\Ginza\my-wiki

# 모델 선택 (기본 sonnet 4.6)
# - claude-haiku-4-5-20251001: 가장 저렴, dev 빠른 반복용
# - claude-sonnet-4-6: 균형 (Phase 1 권장)
# - claude-opus-4-7: 최고 품질, Phase 4 평가용
ANTHROPIC_MODEL=claude-sonnet-4-6
